# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
# Async URL for the app (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5432/carlisle_payreview
# Sync URL for Alembic migrations (psycopg2 driver)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:123456@localhost:5432/carlisle_payreview

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a new one with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production-use-a-long-random-string
SESSION_COOKIE_NAME=carlisle_session
SESSION_LIFETIME_HOURS=8

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Carlisle Pay Review
API_PREFIX=/api/v1
